  <entry>
    <title>生物认证 TouchID/FaceID</title>
    <url>/2022/06/30/authentication-biometrics/</url>
    <content><![CDATA[<link rel="stylesheet" type="text&#x2F;css" href="https://cdn.jsdelivr.net/npm/hexo-tag-hint@0.3.1/dist/hexo-tag-hint.min.css"><h1 id="事前准备"><a href="#事前准备" class="headerlink" title="事前准备"></a>事前准备</h1><p>引入相关的库</p>
<figure class="highlight plaintext"><table><tr><td class="code"><pre><span class="line">LocalAuthentication</span><br></pre></td></tr></table></figure>
<p><img src="/../images/LocalAuthentication.png" alt="LocalAuthentication"></p>
<p>引入头文件</p>
<figure class="highlight objectivec"><table><tr><td class="code"><pre><span class="line"><span class="meta">#import <span class="string">&lt;LocalAuthentication/LocalAuthentication.h&gt;</span></span></span><br></pre></td></tr></table></figure>

<h1 id="使用"><a href="#使用" class="headerlink" title="使用"></a>使用</h1><figure class="highlight objc"><table><tr><td class="code"><pre><span class="line">- (<span class="type">void</span>)faceID &#123;</span><br><span class="line">    </span><br><span class="line">    LAContext *context = [LAContext new];</span><br><span class="line">    context.localizedFallbackTitle = <span class="string">@&quot;localizedFallbackTitle&quot;</span>;</span><br><span class="line">    <span class="built_in">NSError</span> *error;</span><br><span class="line">    LAPolicy policy = LAPolicyDeviceOwnerAuthenticationWithBiometrics;</span><br><span class="line">    <span class="keyword">if</span> ([context canEvaluatePolicy:policy error:&amp;error]) &#123;</span><br><span class="line">        [context evaluatePolicy:policy localizedReason:<span class="string">@&quot;通过Home键验证已有指纹&quot;</span> reply:^(<span class="type">BOOL</span> success, <span class="built_in">NSError</span> * _Nullable error) &#123;</span><br><span class="line">                    <span class="keyword">if</span> (success) &#123;</span><br><span class="line">                        <span class="comment">// success</span></span><br><span class="line">                        MNLog(<span class="keyword">self</span>, <span class="string">@&quot; successed!!!&quot;</span>);</span><br><span class="line">                    &#125; <span class="keyword">else</span> <span class="keyword">if</span> (error) &#123;</span><br><span class="line">                        MNLog(<span class="keyword">self</span>, <span class="string">@&quot; face error.code = %@&quot;</span>, error);</span><br><span class="line">                        <span class="keyword">switch</span> (error.code) &#123;</span><br><span class="line">                            <span class="keyword">case</span> LAErrorAuthenticationFailed:</span><br><span class="line">                                <span class="keyword">break</span>;</span><br><span class="line">                            <span class="keyword">default</span>:</span><br><span class="line">                                <span class="keyword">break</span>;</span><br><span class="line">                        &#125;</span><br><span class="line">                    &#125; <span class="keyword">else</span> &#123;</span><br><span class="line">                        <span class="comment">// other</span></span><br><span class="line">                        MNLog(<span class="keyword">self</span>, <span class="string">@&quot; face id the other reason!!!&quot;</span>);</span><br><span class="line">                    &#125;</span><br><span class="line">        &#125;];</span><br><span class="line">    &#125; <span class="keyword">else</span> &#123;</span><br><span class="line">        <span class="comment">// error</span></span><br><span class="line">        MNLog(<span class="keyword">self</span>, <span class="string">@&quot;还没有设置id, %@&quot;</span>, error);</span><br><span class="line">    &#125;</span><br><span class="line">    </span><br><span class="line">&#125;</span><br></pre></td></tr></table></figure>]]></content>
      <categories>
        <category>iOS开发</category>
      </categories>
      <tags>
        <tag>iOS开发</tag>
        <tag>FaceID</tag>
        <tag>TouchID</tag>
      </tags>
